<ul>
  <% users.forEach(user => { %>
    <li>
      <%= user.name %>
      （<%= user.age !== null ? user.age + "歳" : "年齢未設定" %>）
    </li>
  <% }) %>
</ul>

<h2>ユーザー追加</h2>

<form action="/users" method="post">
  <input type="text" name="name" placeholder="ユーザー名" required>
  <input type="number" name="age" placeholder="年齢" min="0">
  <button type="submit">追加する</button>
</form>

